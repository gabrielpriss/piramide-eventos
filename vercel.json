{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "echo \"Sem dependências npm\"",
  "framework": null,
  "redirects": [
    { "source": "/index-dark-form.html", "destination": "/", "permanent": true },
    { "source": "/index-dark.html", "destination": "/", "permanent": true },
    { "source": "/index-light.html", "destination": "/", "permanent": true },
    { "source": "/index-mixed.html", "destination": "/", "permanent": true },
    { "source": "/index-legacy.html", "destination": "/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
